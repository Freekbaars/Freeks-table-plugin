<Window x:Class="RhinoTable.UI.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RhinoTable — Help"
        Width="540" Height="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#1A3A55"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="HelpTab" TargetType="TabItem">
            <Setter Property="Foreground"      Value="#A8C8E8"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Background"      Value="#0D3050"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="#0D3050" CornerRadius="4,4,0,0"
                                Padding="14,6" Margin="0,0,3,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#163F60"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1B4F7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="3" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A7AB0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Reusable icon chip style -->
        <Style x:Key="IconChip" TargetType="Border">
            <Setter Property="Background"      Value="#0D3050"/>
            <Setter Property="CornerRadius"    Value="3"/>
            <Setter Property="Margin"          Value="0,0,4,4"/>
            <Setter Property="Padding"         Value="5,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#163F60" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <Border Background="#0D3050" CornerRadius="14" Width="28" Height="28"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                    <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/help.png"
                           Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="RhinoTable Help" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="VersionLabel" FontSize="10" Foreground="#7AAACC"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                    Margin="16,12,16,0" Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource HelpTab}"/>
            </TabControl.Resources>

            <!-- ── Keyboard Shortcuts ──────────────────────────────────────── -->
            <TabItem Header="Keyboard Shortcuts">
                <ScrollViewer Background="#163F60" VerticalScrollBarVisibility="Auto" Padding="16,14">
                    <StackPanel>

                        <TextBlock Text="NAVIGATION" Foreground="#4FC3F7" FontSize="10"
                                   FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#0D3050" CornerRadius="3" Padding="7,3" HorizontalAlignment="Left">
                                <TextBlock Text="Tab" FontFamily="Consolas" FontSize="11" Foreground="#4FC3F7"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Move to next cell"
                                       Foreground="#C8E0F4" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#0D3050" CornerRadius="3" Padding="7,3" HorizontalAlignment="Left">
                                <TextBlock Text="Shift + Tab" FontFamily="Consolas" FontSize="11" Foreground="#4FC3F7"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Move to previous cell"
                                       Foreground="#C8E0F4" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#0D3050" CornerRadius="3" Padding="7,3" HorizontalAlignment="Left">
                                <TextBlock Text="↑  ↓  ←  →" FontFamily="Consolas" FontSize="11" Foreground="#4FC3F7"/>
                            </Border>
                            <TextBlock Grid.Column="1" Foreground="#C8E0F4" FontSize="11"
                                       VerticalAlignment="Center" TextWrapping="Wrap" Margin="10,0,0,0"
                                       Text="Navigate between cells (commits current edit)"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#3A7AB0" Margin="0,10,0,10"/>
                        <TextBlock Text="EDITING" Foreground="#4FC3F7" FontSize="10"
                                   FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#0D3050" CornerRadius="3" Padding="7,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl + B" FontFamily="Consolas" FontSize="11" Foreground="#4FC3F7"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Toggle Bold"
                                       Foreground="#C8E0F4" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#0D3050" CornerRadius="3" Padding="7,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl + I" FontFamily="Consolas" FontSize="11" Foreground="#4FC3F7"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Toggle Italic"
                                       Foreground="#C8E0F4" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#0D3050" CornerRadius="3" Padding="7,3" HorizontalAlignment="Left">
                                <TextBlock Text="Delete" FontFamily="Consolas" FontSize="11" Foreground="#4FC3F7"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Clear content of selected cell(s)"
                                       Foreground="#C8E0F4" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#0D3050" CornerRadius="3" Padding="7,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl + C" FontFamily="Consolas" FontSize="11" Foreground="#4FC3F7"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Copy selected cell(s) incl. formatting"
                                       Foreground="#C8E0F4" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#0D3050" CornerRadius="3" Padding="7,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl + V" FontFamily="Consolas" FontSize="11" Foreground="#4FC3F7"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Paste into selected cell(s)"
                                       Foreground="#C8E0F4" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#3A7AB0" Margin="0,10,0,10"/>
                        <TextBlock Text="UNDO / REDO" Foreground="#4FC3F7" FontSize="10"
                                   FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#0D3050" CornerRadius="3" Padding="7,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl + Z" FontFamily="Consolas" FontSize="11" Foreground="#4FC3F7"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Undo (up to 20 steps)"
                                       Foreground="#C8E0F4" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#0D3050" CornerRadius="3" Padding="7,3" HorizontalAlignment="Left">
                                <TextBlock Text="Ctrl + Y" FontFamily="Consolas" FontSize="11" Foreground="#4FC3F7"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Redo"
                                       Foreground="#C8E0F4" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Features ───────────────────────────────────────────────── -->
            <TabItem Header="Features">
                <ScrollViewer Background="#163F60" VerticalScrollBarVisibility="Auto" Padding="16,14">
                    <StackPanel>

                        <!-- STRUCTURE -->
                        <TextBlock Text="STRUCTURE" Foreground="#4FC3F7" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Style="{StaticResource IconChip}" ToolTip="Insert row above">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/row_insert_above.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Insert row below">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/row_insert_below.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Add row at end">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/row_add.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Delete row">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/row_delete.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Insert column left">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/col_insert_left.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Insert column right">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/col_insert_right.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Add column at end">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/col_add.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Delete column">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/col_delete.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Merge cells horizontally">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/merge_horizontal.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Merge cells vertically">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/merge_vertical.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Header row">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/header_row.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Auto-width">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/auto_width.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Auto-number">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/auto_number.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Foreground="#C8E0F4" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,3"
                                   Text="Add, remove and insert rows and columns. Merge adjacent cells horizontally or vertically (click again to unmerge). Mark row 1 as a header row — it automatically gets bold text and a thick bottom border. Auto-width fits all columns to their content; Auto-number fills the first column with sequential numbers."/>

                        <Rectangle Height="1" Fill="#3A7AB0" Margin="0,10,0,10"/>

                        <!-- TEXT -->
                        <TextBlock Text="TEXT" Foreground="#4FC3F7" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Style="{StaticResource IconChip}" ToolTip="Bold (Ctrl+B)">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/text_bold.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Italic (Ctrl+I)">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/text_italic.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Subscript  _{text}">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/text_subscript.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Superscript  ^{text}">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/text_superscript.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Text color">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/text_color.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Word wrap">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/word_wrap.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Align left">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/align_left.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Align center">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/align_center.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Align right">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/align_right.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Align top">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/align_top.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Align middle">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/align_middle.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Align bottom">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/align_bottom.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Foreground="#C8E0F4" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,3"
                                   Text="Format text with Bold (Ctrl+B), Italic (Ctrl+I), Subscript and Superscript. Type _{text} for subscript or ^{text} for superscript directly in a cell. Choose any installed font and size in the properties strip below the toolbar. Align content horizontally (left / center / right) and vertically (top / middle / bottom). Enable Word Wrap to flow long text across multiple lines within the cell."/>

                        <Rectangle Height="1" Fill="#3A7AB0" Margin="0,10,0,10"/>

                        <!-- COLORS -->
                        <TextBlock Text="COLORS" Foreground="#4FC3F7" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Style="{StaticResource IconChip}" ToolTip="Text color">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/text_color.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Fill color">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/fill_color.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Hatch line color">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/hatch_color.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Border color">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/border_color.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Foreground="#C8E0F4" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,3"
                                   Text="Set text color, fill color, hatch line color and border color independently per cell. Use the hex input field for any custom color. The last 12 used colors are saved and shared across all four color pickers."/>

                        <Rectangle Height="1" Fill="#3A7AB0" Margin="0,10,0,10"/>

                        <!-- FILL & HATCH -->
                        <TextBlock Text="FILL &amp; HATCH" Foreground="#4FC3F7" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Style="{StaticResource IconChip}" ToolTip="No fill">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/fill_none.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Solid fill">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/fill_solid.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Fill color">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/fill_color.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Hatch pattern">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/hatch_pattern.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Hatch line color">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/hatch_color.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Refresh hatch list from Rhino document">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/hatch_refresh.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Foreground="#C8E0F4" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,3"
                                   Text="Fill cells with a solid background color or apply a Rhino hatch pattern. Hatch patterns are loaded from the active Rhino document — click the refresh button after adding new patterns. Set the hatch line color, scale and rotation independently of the background fill."/>

                        <Rectangle Height="1" Fill="#3A7AB0" Margin="0,10,0,10"/>

                        <!-- BORDERS -->
                        <TextBlock Text="BORDERS" Foreground="#4FC3F7" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Style="{StaticResource IconChip}" ToolTip="Remove all borders">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/border_none.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="All borders">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/border_all.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Outside border only">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/border_outside.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Top border">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/border_top.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Bottom border">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/border_bottom.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Left border">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/border_left.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Right border">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/border_right.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Thin border (0.25 mm)">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/border_thin.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Thick border (0.5 mm)">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/border_thick.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Border color">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/border_color.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Foreground="#C8E0F4" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,3"
                                   Text="Apply borders to all sides, outside only, or toggle individual sides (top / bottom / left / right). Each side can be thin (0.25 mm) or thick (0.5 mm) with its own color. Borders are drawn per cell with no overlapping lines between adjacent cells."/>

                        <Rectangle Height="1" Fill="#3A7AB0" Margin="0,10,0,10"/>

                        <!-- TEMPLATES -->
                        <TextBlock Text="TEMPLATES" Foreground="#4FC3F7" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Style="{StaticResource IconChip}" ToolTip="Templates">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/templates.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Place table in Rhino">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/place_table.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Foreground="#C8E0F4" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,3"
                                   Text="Save any table layout as a reusable template and load it whenever you need it. Five built-in templates are included: Drawing Title Block, Bill of Materials (BOM), Revision Table, Material Legend, and two dynamic BOM generators that auto-populate from the Rhino model."/>

                        <Rectangle Height="1" Fill="#3A7AB0" Margin="0,10,0,10"/>

                        <!-- IMPORT -->
                        <TextBlock Text="IMPORT" Foreground="#4FC3F7" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Style="{StaticResource IconChip}" ToolTip="Import CSV">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/import_csv.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Import Excel (.xlsx)">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/import_excel.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Link to Excel file (live sync)">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/link_excel.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Border Style="{StaticResource IconChip}" ToolTip="Refresh linked Excel file">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/refresh_link.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Foreground="#C8E0F4" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,3"
                                   Text="Import data from a CSV file (auto-detects , ; | tab separators, max 500 rows) or an Excel workbook (.xlsx). When importing Excel, choose a sheet from a popup if multiple sheets are available. Link to an Excel file for live updates — the table refreshes automatically when the file is saved, or click Refresh to pull changes manually."/>

                        <Rectangle Height="1" Fill="#3A7AB0" Margin="0,10,0,10"/>

                        <!-- AUTO-UPDATE -->
                        <TextBlock Text="AUTO-UPDATE" Foreground="#4FC3F7" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Style="{StaticResource IconChip}" ToolTip="Update table in Rhino">
                                <Image Source="pack://application:,,,/RhinoTable.UI;component/Resources/Icons/4x/update_table.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Foreground="#C8E0F4" FontSize="11" TextWrapping="Wrap"
                                   Text="RhinoTable checks the Yak package manager once per day on startup. If a newer version is available, a notification appears with a direct link to the Package Manager. Use TableSync in the Rhino command line to manually refresh all linked tables in the document."/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#163F60" Padding="16,10">
            <Grid>
                <TextBlock Text="github.com/Freekbaars/Freeks-table-plugin"
                           Foreground="#3A7AB0" FontSize="10" VerticalAlignment="Center"
                           TextDecorations="Underline" Cursor="Hand"
                           HorizontalAlignment="Left"
                           MouseLeftButtonUp="GitHub_Click"/>
                <Button Content="Close" Width="72" Height="28"
                        HorizontalAlignment="Right"
                        Click="Close_Click"
                        Background="#2A6A9E" Foreground="White"
                        BorderBrush="#3A7AB0" BorderThickness="1"
                        Style="{StaticResource CloseBtn}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
