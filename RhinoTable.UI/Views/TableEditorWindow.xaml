                                                    <Border Background="#C0392B" Width="13" Height="13" CornerRadius="2"/>
                                                </Button>
                                                <Button Command="{Binding SetBorderColorCommand}" CommandParameter="#E67E22"
                                                        Click="ColorPopupButton_Click" Tag="{Binding ElementName=BorderColorToggle}"
                                                        Style="{StaticResource SwatchButton}" Width="22" Height="22" ToolTip="Orange">
                                                    <Border Background="#E67E22" Width="13" Height="13" CornerRadius="2"/>
                                                </Button>
                                                <Button Command="{Binding SetBorderColorCommand}" CommandParameter="#1E8449"
                                                        Click="ColorPopupButton_Click" Tag="{Binding ElementName=BorderColorToggle}"
                                                        Style="{StaticResource SwatchButton}" Width="22" Height="22" ToolTip="Green">
                                                    <Border Background="#1E8449" Width="13" Height="13" CornerRadius="2"/>
                                                </Button>
                                                <Button Command="{Binding SetBorderColorCommand}" CommandParameter="#2980B9"
                                                        Click="ColorPopupButton_Click" Tag="{Binding ElementName=BorderColorToggle}"
                                                        Style="{StaticResource SwatchButton}" Width="22" Height="22" ToolTip="Blue">
                                                    <Border Background="#2980B9" Width="13" Height="13" CornerRadius="2"/>
                                                </Button>
                                            </WrapPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBox Width="82" Text="#" FontFamily="Consolas" FontSize="11"
                                                         Padding="4,2" MaxLength="7"
                                                         Background="#0D3050" Foreground="#CCDDEE" CaretBrush="White"
                                                         BorderBrush="#3A7AB0" BorderThickness="1"
                                                         VerticalContentAlignment="Center"
                                                         ToolTip="Enter a hex color code, e.g. #C0392B"/>
                                                <Button Content="✓" Margin="4,0,0,0" Width="22" Height="22"
                                                        Click="ApplyHexBorderColor_Click"
                                                        Style="{StaticResource SwatchButton}"
                                                        ToolTip="Apply border color"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>

                            <!-- Rij 2: per-zijde knoppen -->
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Button Command="{Binding BorderTopCommand}"
                                        ToolTip="Toggle top border"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/border_top.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                                <Button Command="{Binding BorderBottomCommand}"
                                        ToolTip="Toggle bottom border"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/border_bottom.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                                <Button Command="{Binding BorderLeftCommand}"
                                        ToolTip="Toggle left border"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/border_left.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                                <Button Command="{Binding BorderRightCommand}"
                                        ToolTip="Toggle right border"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/border_right.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                            </StackPanel>

                        </StackPanel>
                    </StackPanel>
                </Border>

                <Rectangle Style="{StaticResource GroupSep}"/>

                <!-- ── IMPORT ─────────────────────────────────────────────── -->
                <Border Style="{StaticResource ToolGroup}" Padding="6,4">
                    <StackPanel>
                        <TextBlock Text="IMPORT" Style="{StaticResource GroupLabel}"/>
                        <StackPanel Orientation="Vertical" Width="87">
                            <Button Command="{Binding ImportCsvCommand}"
                                    Style="{StaticResource ToolbarButton}" HorizontalContentAlignment="Left"
                                    Padding="6,4" Margin="0,0,0,2" ToolTip="Import CSV file" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/import_csv.png" Width="18" Height="18" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text=" CSV" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ImportExcelCommand}"
                                    Style="{StaticResource ToolbarButton}" HorizontalContentAlignment="Left"
                                    Padding="6,4" Margin="0,0,0,2" ToolTip="Import Excel file" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/import_excel.png" Width="18" Height="18" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text=" Excel" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding LinkExcelCommand}"
                                    Style="{StaticResource ToolbarButton}" HorizontalContentAlignment="Left"
                                    Padding="6,4" Margin="0,0,0,2" ToolTip="Link to Excel file (live update)" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/link_excel.png" Width="18" Height="18" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text=" Link Excel" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding RefreshLinkedCommand}"
                                    Style="{StaticResource ToolbarButton}" HorizontalContentAlignment="Left"
                                    Padding="6,4" ToolTip="Refresh linked Excel data" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/refresh_link.png" Width="18" Height="18" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text=" Refresh" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Rectangle Style="{StaticResource GroupSep}"/>

                <!-- ── UTILITIES ──────────────────────────────────────────── -->
                <Border Style="{StaticResource ToolGroup}" Padding="6,4" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform AngleY="0.486"/>
                            <RotateTransform/>
                            <TranslateTransform Y="0.501"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="UTILITIES" Style="{StaticResource GroupLabel}"/>
                        <Button Command="{Binding AutoNumberCommand}"
                                Style="{StaticResource ToolbarButton}" HorizontalContentAlignment="Left"
                                Padding="6,4" ToolTip="Fill first column with row numbers (skips header rows)">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/auto_number.png" Width="18" Height="18" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text=" Auto-number" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Bijzondere tekens dropdown -->
                        <ToggleButton x:Name="SpecialCharToggle"
                                      Style="{StaticResource DropdownToggleButton}"
                                      Focusable="False"
                                      Padding="6,3" Height="26"
                                      HorizontalContentAlignment="Left"
                                      ToolTip="Insert a special character at the cursor position">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Ω" FontFamily="Segoe UI Symbol" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text=" Special ▼" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                        <Popup x:Name="SpecialCharPopup"
                               PlacementTarget="{Binding ElementName=SpecialCharToggle}"
                               Placement="Bottom"
                               IsOpen="{Binding IsChecked, ElementName=SpecialCharToggle, Mode=TwoWay}"
                               StaysOpen="False"
                               Opened="SpecialCharPopup_Opened">
                            <Border Background="#163F60" Padding="8" CornerRadius="4"
                                    BorderBrush="#3A7AB0" BorderThickness="1">
                                <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel x:Name="SpecialCharPanel"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>

                        <!-- Rhino text fields dropdown -->
                        <ToggleButton x:Name="FieldsToggle"
                                      Style="{StaticResource DropdownToggleButton}"
                                      Focusable="False"
                                      Padding="6,3" Height="26"
                                      HorizontalContentAlignment="Left"
                                      ToolTip="Insert a Rhino text field at the cursor position">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊞" FontFamily="Segoe UI Symbol" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text=" Fields ▼" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                        <Popup x:Name="FieldsPopup"
                               PlacementTarget="{Binding ElementName=FieldsToggle}"
                               Placement="Bottom"
                               IsOpen="{Binding IsChecked, ElementName=FieldsToggle, Mode=TwoWay}"
                               StaysOpen="False"
                               Opened="FieldsPopup_Opened">
                            <Border Background="#163F60" Padding="8" CornerRadius="4"
                                    BorderBrush="#3A7AB0" BorderThickness="1" MinWidth="280">
                                <ScrollViewer MaxHeight="480" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel x:Name="FieldsPanel"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Border>

                <Rectangle Style="{StaticResource GroupSep}"/>

                <!-- ── HELP ───────────────────────────────────────────────── -->
                <Border Style="{StaticResource ToolGroup}" Padding="6,4">
                    <Button Click="OpenHelp_Click"
                            Style="{StaticResource ToolbarButton}"
                            Padding="8,4" ToolTip="Show keyboard shortcuts and feature overview">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/help.png" Width="18" Height="18" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text=" Help" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             Eigenschappen strip
        ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="#D0D8E0" BorderThickness="0,0,0,1" Padding="12,5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="Table name" Style="{StaticResource PropLabel}"/>
                <TextBox Width="110" Text="{Binding TableName, UpdateSourceTrigger=LostFocus}"
                         Style="{StaticResource PropBox}" Margin="0,0,20,0"
                         ToolTip="Name of the Rhino block (empty = auto)"/>

                <TextBlock Text="Width (mm)" Style="{StaticResource PropLabel}"/>
                <TextBox Width="52" Text="{Binding SelectedColumnWidth, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                         Style="{StaticResource PropBox}" Margin="0,0,16,0"/>

                <TextBlock Text="Height (mm)" Style="{StaticResource PropLabel}"/>
                <TextBox Width="52" Text="{Binding SelectedRowHeight, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                         Style="{StaticResource PropBox}"/>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             DataGrid
        ══════════════════════════════════════════════════════════════════ -->
        <DataGrid x:Name="TableGrid" Grid.Row="2"
                  ItemsSource="{Binding GridItems}"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserResizeRows="True"
                  AutoGenerateColumns="False"
                  SelectionUnit="Cell"
                  SelectionMode="Extended"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  HeadersVisibility="All"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#D8DDE3"
                  VerticalGridLinesBrush="#D8DDE3"
                  SelectedCellsChanged="TableGrid_SelectedCellsChanged"
                  CellEditEnding="TableGrid_CellEditEnding"
                  PreviewKeyDown="TableGrid_PreviewKeyDown"
                  ColumnReordered="TableGrid_ColumnReordered"/>

        <!-- ══════════════════════════════════════════════════════════════════
             Statusbalk
        ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#1B4F7A">
            <TextBlock Text="{Binding StatusText}" Foreground="White"
                       Padding="12,4" VerticalAlignment="Center" FontSize="11"/>
        </Border>

    </Grid>
</Window>
