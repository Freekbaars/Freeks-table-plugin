<Window x:Class="RhinoTable.UI.Views.TableEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:RhinoTable.UI.Converters"
        x:Name="EditorWindow"
        Title="RhinoTable — Table Editor"
        Width="1500" Height="690"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#F2F5F8">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/TableEditorTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:HatchNameToBrushConverter x:Key="HatchNameToBrush"/>
        </ResourceDictionary>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Return" Modifiers="Ctrl" Command="{Binding PlaceTableCommand}"/>
        <KeyBinding Key="B"      Modifiers="Ctrl" Command="{Binding BoldCommand}"/>
        <KeyBinding Key="I"      Modifiers="Ctrl" Command="{Binding ItalicCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Ribbon toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Eigenschappen-strip -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="26"/>
            <!-- Statusbalk -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════
             RIBBON TOOLBAR
        ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1B4F7A" Padding="6,6,6,4">
            <StackPanel Orientation="Horizontal">

                <!-- ── PLAATSEN + SJABLONEN ─────────────────────────────── -->
                <Border Style="{StaticResource ToolGroup}" Padding="8,4">
                    <StackPanel>
                        <Button Command="{Binding PlaceTableCommand}"
                                ToolTip="Place or update table in Rhino (Ctrl+Enter)"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="90" Height="38" Click="Button_Click_2">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Width="25" Height="25" HorizontalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/place_table.png"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditingExisting}" Value="True">
                                                    <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/update_table.png"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="{Binding PlaceButtonLabel}"
                                           FontSize="10" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="OpenTemplatesButton"
                                Click="OpenTemplates_Click"
                                Style="{StaticResource ToolbarButton}"
                                Height="62" Margin="0,3,0,0"
                                ToolTip="Sjablonenmanager — laad ingebouwde layouts of bewaar eigen sjablonen">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/templates.png"
                                       Width="28" Height="47"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text=" Templates" FontSize="9" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Rectangle Style="{StaticResource GroupSep}"/>

                <!-- ── STRUCTUUR: rijen + kolommen in 2×4 grid ───────────── -->
                <Border Style="{StaticResource ToolGroup}" Padding="6,4">
                    <StackPanel>
                        <TextBlock Text="STRUCTURE" Style="{StaticResource GroupLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26"/>
                                <ColumnDefinition Width="26"/>
                                <ColumnDefinition Width="26"/>
                                <ColumnDefinition Width="26"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                            </Grid.RowDefinitions>

                            <!-- Rij-operaties -->
                            <Button Grid.Row="0" Grid.Column="0"
                                    Command="{Binding InsertRowAboveCommand}"
                                    ToolTip="Insert row above"
                                    Style="{StaticResource ToolbarButton}" Padding="2,3">
                                <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/row_insert_above.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Grid.Row="0" Grid.Column="1"
                                    Command="{Binding InsertRowBelowCommand}"
                                    ToolTip="Insert row below"
                                    Style="{StaticResource ToolbarButton}" Padding="2,3">
                                <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/row_insert_below.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Grid.Row="0" Grid.Column="2"
                                    Command="{Binding AddRowCommand}"
                                    ToolTip="Add row at end"
                                    Style="{StaticResource ToolbarButton}" Padding="2,3">
                                <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/row_add.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Grid.Row="0" Grid.Column="3"
                                    Command="{Binding RemoveRowCommand}"
                                    ToolTip="Delete selected row"
                                    Style="{StaticResource DangerButton}" Padding="2,3">
                                <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/row_delete.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>

                            <!-- Kolom-operaties -->
                            <Button Grid.Row="1" Grid.Column="0"
                                    Command="{Binding InsertColumnLeftCommand}"
                                    ToolTip="Insert column left"
                                    Style="{StaticResource ToolbarButton}" Padding="2,3">
                                <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/col_insert_left.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="1"
                                    Command="{Binding InsertColumnRightCommand}"
                                    ToolTip="Insert column right"
                                    Style="{StaticResource ToolbarButton}" Padding="2,3">
                                <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/col_insert_right.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="2"
                                    Command="{Binding AddColumnCommand}"
                                    ToolTip="Add column at end"
                                    Style="{StaticResource ToolbarButton}" Padding="2,3">
                                <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/col_add.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="3"
                                    Command="{Binding RemoveColumnCommand}"
                                    ToolTip="Delete selected column"
                                    Style="{StaticResource DangerButton}" Padding="2,3">
                                <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/col_delete.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                        </Grid>

                        <!-- Header-rij toggle (alleen rij 1) -->
                        <ToggleButton Margin="0,4,0,0" Height="22" Padding="6,2"
                                      IsChecked="{Binding IsCurrentRowHeader, Mode=OneWay}"
                                      Command="{Binding ToggleHeaderRowCommand}"
                                      Style="{StaticResource DropdownToggleButton}"
                                      ToolTip="Make row 1 a header (bold + thick border). Only available on row 1.">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/header_row.png"
                                       Width="13" Height="13" VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text=" Header row" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>
                </Border>

                <Rectangle Style="{StaticResource GroupSep}"/>

                <!-- ── TEKST ──────────────────────────────────────────────── -->
                <Border Style="{StaticResource ToolGroup}" Padding="6,4">
                    <StackPanel>
                        <TextBlock Text="TEXT" Style="{StaticResource GroupLabel}"/>
                        <StackPanel Orientation="Vertical">

                            <!-- Rij 1: B I sub sup | Tekstkleur -->
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding BoldCommand}"
                                        ToolTip="Bold (Ctrl+B)"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/text_bold.png"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBold}" Value="True">
                                                        <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/text_bold_active.png"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Button>
                                <Button Command="{Binding ItalicCommand}"
                                        ToolTip="Italic (Ctrl+I)"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/text_italic.png"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsItalic}" Value="True">
                                                        <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/text_italic_active.png"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Button>
                                <Button Command="{Binding InsertSubCommand}"
                                        ToolTip="Insert subscript: _{text}"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/text_subscript.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                                <Button Command="{Binding InsertSupCommand}"
                                        ToolTip="Insert superscript: ^{text}"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/text_superscript.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                                <Rectangle Width="1" Fill="#FFFFFF" Opacity="0.2" Margin="3,4"/>
                                <!-- Tekstkleur toggle -->
                                <ToggleButton x:Name="TextColorToggle"
                                              Style="{StaticResource DropdownToggleButton}"
                                              ToolTip="Choose text color"
                                              Height="26" MinWidth="46">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/text_color.png" Width="20" Height="20" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="▼" FontSize="8" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ToggleButton>
                                <Popup PlacementTarget="{Binding ElementName=TextColorToggle}"
                                       Placement="Bottom"
                                       IsOpen="{Binding IsChecked, ElementName=TextColorToggle, Mode=TwoWay}"
                                       StaysOpen="False"
                                       DataContext="{Binding DataContext, ElementName=EditorWindow}">
                                    <Border Background="#163F60" Padding="7" CornerRadius="4"
                                            BorderBrush="#3A7AB0" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Text color" Foreground="#A8C8E8" FontSize="9" Margin="0,0,0,5"/>
                                            <!-- Recente kleuren -->
                                            <StackPanel Margin="0,0,0,5">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RecentColors.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="Recent" Foreground="#7AAACC" FontSize="9" Margin="0,0,0,3"/>
                                                <ItemsControl ItemsSource="{Binding RecentColors}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Width="164"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Width="22" Height="22"
                                                                    Style="{StaticResource SwatchButton}"
                                                                    Command="{Binding DataContext.SetTextColorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Click="RecentColor_Click"
                                                                    Tag="TextColorToggle"
                                                                    ToolTip="{Binding}">
                                                                <Border Width="13" Height="13" CornerRadius="2" Background="{Binding}"/>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Rectangle Height="1" Fill="#3A7AB0" Margin="0,4,0,2"/>
                                            </StackPanel>
                                            <WrapPanel Width="164">
                                                <Button Command="{Binding SetTextColorCommand}" CommandParameter=""
                                                        Click="ColorPopupButton_Click" Tag="{Binding ElementName=TextColorToggle}"
                                                        Style="{StaticResource SwatchButton}" Width="22" Height="22"
                                                        ToolTip="Remove text color (black)">
                                                    <TextBlock Text="✕" FontSize="9" Foreground="#CCC"/>
                                                </Button>
                                                <Button Command="{Binding SetTextColorCommand}" CommandParameter="#000000"
                                                        Click="ColorPopupButton_Click" Tag="{Binding ElementName=TextColorToggle}"
                                                        Style="{StaticResource SwatchButton}" Width="22" Height="22" ToolTip="Black">
                                                    <Border Background="#000000" Width="13" Height="13" CornerRadius="2"/>
                                                </Button>
                                                <Button Command="{Binding SetTextColorCommand}" CommandParameter="#555555"
                                                        Click="ColorPopupButton_Click" Tag="{Binding ElementName=TextColorToggle}"
                                                        Style="{StaticResource SwatchButton}" Width="22" Height="22" ToolTip="Dark grey">
                                                    <Border Background="#555555" Width="13" Height="13" CornerRadius="2"/>
                                                </Button>
                                                <Button Command="{Binding SetTextColorCommand}" CommandParameter="#C0392B"
                                                        Click="ColorPopupButton_Click" Tag="{Binding ElementName=TextColorToggle}"
                                                        Style="{StaticResource SwatchButton}" Width="22" Height="22" ToolTip="Red">
                                                    <Border Background="#C0392B" Width="13" Height="13" CornerRadius="2"/>
                                                </Button>
                                                <Button Command="{Binding SetTextColorCommand}" CommandParameter="#E67E22"
                                                        Click="ColorPopupButton_Click" Tag="{Binding ElementName=TextColorToggle}"
                                                        Style="{StaticResource SwatchButton}" Width="22" Height="22" ToolTip="Orange">
                                                    <Border Background="#E67E22" Width="13" Height="13" CornerRadius="2"/>
                                                </Button>
                                                <Button Command="{Binding SetTextColorCommand}" CommandParameter="#D4AC0D"
                                                        Click="ColorPopupButton_Click" Tag="{Binding ElementName=TextColorToggle}"
                                                        Style="{StaticResource SwatchButton}" Width="22" Height="22" ToolTip="Yellow">
                                                    <Border Background="#D4AC0D" Width="13" Height="13" CornerRadius="2"/>
                                                </Button>
                                                <Button Command="{Binding SetTextColorCommand}" CommandParameter="#1E8449"
                                                        Click="ColorPopupButton_Click" Tag="{Binding ElementName=TextColorToggle}"
                                                        Style="{StaticResource SwatchButton}" Width="22" Height="22" ToolTip="Green">
                                                    <Border Background="#1E8449" Width="13" Height="13" CornerRadius="2"/>
                                                </Button>
                                                <Button Command="{Binding SetTextColorCommand}" CommandParameter="#2980B9"
                                                        Click="ColorPopupButton_Click" Tag="{Binding ElementName=TextColorToggle}"
                                                        Style="{StaticResource SwatchButton}" Width="22" Height="22" ToolTip="Blue">
                                                    <Border Background="#2980B9" Width="13" Height="13" CornerRadius="2"/>
                                                </Button>
                                                <Button Command="{Binding SetTextColorCommand}" CommandParameter="#8E44AD"
                                                        Click="ColorPopupButton_Click" Tag="{Binding ElementName=TextColorToggle}"
                                                        Style="{StaticResource SwatchButton}" Width="22" Height="22" ToolTip="Purple">
                                                    <Border Background="#8E44AD" Width="13" Height="13" CornerRadius="2"/>
                                                </Button>
                                            </WrapPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBox Width="82" Text="#" FontFamily="Consolas" FontSize="11"
                                                         Padding="4,2" MaxLength="7"
                                                         Background="#0D3050" Foreground="#CCDDEE" CaretBrush="White"
                                                         BorderBrush="#3A7AB0" BorderThickness="1"
                                                         VerticalContentAlignment="Center"
                                                         ToolTip="Enter a hex color code, e.g. #FF4444"/>
                                                <Button Content="✓" Margin="4,0,0,0" Width="22" Height="22"
                                                        Click="ApplyHexTextColor_Click"
                                                        Style="{StaticResource SwatchButton}"
                                                        ToolTip="Apply color"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>

                            <!-- Rij 2: Lettertype dropdown | Grootte -->
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <ComboBox Width="120"
                                          Style="{StaticResource PropComboBox}"
                                          Text="{Binding SelectedCellFont, UpdateSourceTrigger=LostFocus}"
                                          ItemsSource="{Binding AvailableFonts}"
                                          ToolTip="Choose font">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       FontFamily="{Binding}"
                                                       FontSize="12"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBox Width="44"
                                         Text="{Binding SelectedCellFontSize, UpdateSourceTrigger=LostFocus}"
                                         Style="{StaticResource PropBox}" Margin="3,0,0,0"
                                         ToolTip="Font size in points"/>
                            </StackPanel>

                        </StackPanel>
                    </StackPanel>
                </Border>

                <Rectangle Style="{StaticResource GroupSep}"/>

                <!-- ── UITLIJNING ──────────────────────────────────────────── -->
                <Border Style="{StaticResource ToolGroup}" Padding="6,4">
                    <StackPanel>
                        <TextBlock Text="ALIGNMENT" Style="{StaticResource GroupLabel}"/>
                        <StackPanel Orientation="Vertical">

                            <!-- Rij 1: H-uitlijning | V-uitlijning | terugloop -->
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding AlignLeftCommand}"
                                        ToolTip="Align left"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/align_left.png"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAlignLeft}" Value="True">
                                                        <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/align_left_active.png"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Button>
                                <Button Command="{Binding AlignCenterCommand}"
                                        ToolTip="Center"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/align_center.png"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAlignCenter}" Value="True">
                                                        <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/align_center_active.png"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Button>
                                <Button Command="{Binding AlignRightCommand}"
                                        ToolTip="Align right"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/align_right.png"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAlignRight}" Value="True">
                                                        <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/align_right_active.png"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Button>
                                <Rectangle Width="1" Fill="#FFFFFF" Opacity="0.2" Margin="3,4"/>
                                <Button Command="{Binding AlignTopCommand}"
                                        ToolTip="Align text to top of cell"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/align_top.png"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAlignTop}" Value="True">
                                                        <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/align_top_active.png"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Button>
                                <Button Command="{Binding AlignMiddleCommand}"
                                        ToolTip="Center text vertically"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/align_middle.png"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAlignMiddle}" Value="True">
                                                        <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/align_middle_active.png"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Button>
                                <Button Command="{Binding AlignBottomCommand}"
                                        ToolTip="Align text to bottom of cell"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/align_bottom.png"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAlignBottom}" Value="True">
                                                        <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/align_bottom_active.png"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Button>
                                <Rectangle Width="1" Fill="#FFFFFF" Opacity="0.2" Margin="3,4"/>
                                <Button Command="{Binding ToggleWordWrapCommand}"
                                        ToolTip="Toggle word wrap"
                                        Style="{StaticResource ToolbarButton}" Width="26" Padding="2,3">
                                    <Image Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/word_wrap.png"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsWordWrap}" Value="True">
                                                        <Setter Property="Source" Value="/RhinoTable.UI;component/Resources/Icons/4x/word_wrap_active.png"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Button>
                            </StackPanel>

                            <!-- Rij 2: samenvoegen -->
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Button Command="{Binding MergeCellsCommand}"
                                        ToolTip="Merge selected cells horizontally (click again to unmerge)"
                                        Style="{StaticResource ToolbarButton}" Padding="5,3" Margin="0,0,2,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/merge_horizontal.png" Width="20" Height="20" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text=" Merge" FontSize="10" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding MergeDownCommand}"
                                        ToolTip="Merge selected cells vertically (click again to unmerge)"
                                        Style="{StaticResource ToolbarButton}" Padding="5,3">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/merge_vertical.png" Width="20" Height="20" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text=" Merge" FontSize="10" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <Button Command="{Binding AutoWidthCommand}"
                                    Style="{StaticResource ToolbarButton}" HorizontalContentAlignment="Left"
                                    Padding="5,3"
                                    ToolTip="Fit column widths to content" Width="122" HorizontalAlignment="Left" Click="Button_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/RhinoTable.UI;component/Resources/Icons/4x/auto_width.png" Width="20" Height="20" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text=" Auto-width" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Rij 3: auto-width -->
                        </StackPanel>
                    </StackPanel>
                </Border>

