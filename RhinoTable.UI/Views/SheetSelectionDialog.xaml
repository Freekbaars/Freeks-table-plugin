<Window x:Class="RhinoTable.UI.Views.SheetSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Worksheet"
        Width="340" Height="290"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#F2F5F8">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="This file contains multiple worksheets. Select one to import:"
                   FontWeight="Bold" FontSize="11" Foreground="#1B4F7A"
                   TextWrapping="Wrap" Margin="0,0,0,10"/>

        <ListBox x:Name="SheetList" Grid.Row="1"
                 BorderBrush="#C0CDD8" BorderThickness="1"
                 FontSize="13" Margin="0,0,0,14"
                 MouseDoubleClick="SheetList_DoubleClick"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Height="28" Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Select" Width="80" Height="28" IsDefault="True"
                    Click="Ok_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background"  Value="#1B4F7A"/>
                        <Setter Property="Foreground"  Value="White"/>
                        <Setter Property="BorderBrush" Value="#2A6A9E"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1" CornerRadius="3" Padding="8,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2A6A9E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
