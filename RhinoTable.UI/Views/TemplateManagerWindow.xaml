<Window x:Class="RhinoTable.UI.Views.TemplateManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RhinoTable — Sjablonen"
        Width="680" Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F2F5F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Koptekst -->
            <RowDefinition Height="*"/>      <!-- Inhoud -->
            <RowDefinition Height="Auto"/>   <!-- Knoppen -->
        </Grid.RowDefinitions>

        <!-- ── Koptekst ── -->
        <Border Grid.Row="0" Background="#1B4F7A" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x1F4CB;" FontSize="18" Foreground="#4FC3F7"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Tabel Sjablonen" Foreground="White"
                               FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="Laad een ingebouwd sjabloon of bewaar je eigen tabelopmaak"
                               Foreground="#8AB4D0" FontSize="10"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Inhoud: lijst + details ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="5"/>      <!-- Splitter -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Lijst -->
            <Border Grid.Column="0" Background="White"
                    BorderBrush="#D0D8E0" BorderThickness="0,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="SJABLONEN" Foreground="#1B4F7A"
                               FontSize="9" FontWeight="Bold"
                               Padding="10,8,8,4" Background="#EEF3F8"/>
                    <ListBox x:Name="TemplateList"
                             SelectionChanged="TemplateList_SelectionChanged"
                             BorderThickness="0"
                             Background="White"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"       Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush"   Value="#EEF0F2"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EEF6FF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#D6EAF8"/>
                                        <Setter Property="Foreground" Value="#1B4F7A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="eigen sjabloon"/>
                                                <Setter Property="Foreground" Value="#7F8C8D"/>
                                                <Setter Property="FontSize"   Value="10"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                        <Setter Property="Text" Value="ingebouwd"/>
                                                        <Setter Property="Foreground" Value="#2980B9"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#D0D8E0" ShowsPreview="False"/>

            <!-- Details -->
            <Border Grid.Column="2" Padding="20,16" Background="White">
                <StackPanel x:Name="DetailPanel">
                    <!-- Naam -->
                    <TextBlock Text="Naam" Foreground="#1B4F7A"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="TemplateNameBox"
                             FontSize="13" Padding="6,4"
                             BorderBrush="#C0CDD8" BorderThickness="1"
                             IsReadOnly="False"
                             Margin="0,0,0,14"
                             ToolTip="Naam van het sjabloon (aanpasbaar voor eigen sjablonen)"/>

                    <!-- Beschrijving -->
                    <TextBlock Text="Beschrijving" Foreground="#1B4F7A"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="TemplateDescBox"
                             FontSize="11" Padding="6,4"
                             BorderBrush="#C0CDD8" BorderThickness="1"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             Height="80" VerticalScrollBarVisibility="Auto"
                             IsReadOnly="False"
                             Margin="0,0,0,16"
                             ToolTip="Korte omschrijving van het sjabloon"/>

                    <!-- Info chip: ingebouwd / eigen -->
                    <Border x:Name="TypeChip" CornerRadius="3"
                            Padding="8,3" HorizontalAlignment="Left"
                            Margin="0,0,0,0">
                        <TextBlock x:Name="TypeLabel" FontSize="10" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Knoppen onderaan ── -->
        <Border Grid.Row="2" Background="#EEF3F8"
                BorderBrush="#D0D8E0" BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="SaveButton"
                            Content="&#x1F4BE;  Opslaan als sjabloon"
                            Click="Save_Click"
                            Padding="10,6" Margin="0,0,8,0"
                            ToolTip="Bewaar de huidige tabelopmaak als nieuw sjabloon">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="#2A6A9E"/>
                                <Setter Property="Foreground"   Value="White"/>
                                <Setter Property="BorderBrush"  Value="#3A7AB0"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor"       Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3A7AB0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="DeleteButton"
                            Content="&#x1F5D1;  Verwijderen"
                            Click="Delete_Click"
                            Padding="10,6"
                            IsEnabled="False"
                            ToolTip="Verwijder dit eigen sjabloon (ingebouwde kunnen niet worden verwijderd)">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="#C0392B"/>
                                <Setter Property="Foreground"   Value="White"/>
                                <Setter Property="BorderBrush"  Value="#E74C3C"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor"       Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E74C3C"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Annuleren"
                            Width="90" Height="32"
                            Click="Cancel_Click"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="White"/>
                                <Setter Property="Foreground"   Value="#333"/>
                                <Setter Property="BorderBrush"  Value="#C0CDD8"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor"       Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3" Padding="8,4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F0F4F8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="LoadButton"
                            Content="&#x25B6;  Laden"
                            Width="100" Height="32"
                            IsEnabled="False"
                            Click="Load_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="#1B4F7A"/>
                                <Setter Property="Foreground"   Value="White"/>
                                <Setter Property="BorderBrush"  Value="#2A6A9E"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontWeight"   Value="SemiBold"/>
                                <Setter Property="Cursor"       Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3" Padding="8,4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2A6A9E"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
