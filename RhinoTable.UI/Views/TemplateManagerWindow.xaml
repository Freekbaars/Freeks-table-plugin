<Window x:Class="RhinoTable.UI.Views.TemplateManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RhinoTable — Templates"
        Width="700" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F2F5F8">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="FilterTab" TargetType="RadioButton">
            <Setter Property="Foreground"       Value="#4A7FA8"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0,0,0,2"/>
            <Setter Property="BorderBrush"      Value="Transparent"/>
            <Setter Property="Padding"          Value="12,5"/>
            <Setter Property="Margin"           Value="0,0,2,0"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="GroupName"        Value="Filter"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1B4F7A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="BorderBrush" Value="#1B4F7A"/>
                                <Setter Property="Foreground"  Value="#1B4F7A"/>
                                <Setter Property="FontWeight"  Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Koptekst -->
            <RowDefinition Height="Auto"/>   <!-- Filter tabs -->
            <RowDefinition Height="*"/>      <!-- Inhoud -->
            <RowDefinition Height="Auto"/>   <!-- Knoppen -->
        </Grid.RowDefinitions>

        <!-- ── Koptekst ── -->
        <Border Grid.Row="0" Background="#1B4F7A" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x1F4CB;" FontSize="18" Foreground="#4FC3F7"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Table Templates" Foreground="White"
                               FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="Load a template or save the current table as a custom template"
                               Foreground="#8AB4D0" FontSize="10"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Filter tabs ── -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="#D0D8E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="6,0">
                <RadioButton x:Name="FilterAll"
                             Content="All" IsChecked="True"
                             Style="{StaticResource FilterTab}"
                             Checked="Filter_Checked"/>
                <RadioButton x:Name="FilterBuiltIn"
                             Content="Built-in"
                             Style="{StaticResource FilterTab}"
                             Checked="Filter_Checked"/>
                <RadioButton x:Name="FilterDynamic"
                             Content="Dynamic"
                             Style="{StaticResource FilterTab}"
                             Checked="Filter_Checked"/>
                <RadioButton x:Name="FilterCustom"
                             Content="Custom"
                             Style="{StaticResource FilterTab}"
                             Checked="Filter_Checked"/>
            </StackPanel>
        </Border>

        <!-- ── Inhoud: lijst + details ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="160"/>
                <ColumnDefinition Width="5"/>      <!-- Splitter -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Lijst -->
            <Border Grid.Column="0" Background="White"
                    BorderBrush="#D0D8E0" BorderThickness="0,0,0,0">
                <ListBox x:Name="TemplateList"
                         SelectionChanged="TemplateList_SelectionChanged"
                         BorderThickness="0"
                         Background="White"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"       Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush"   Value="#EEF0F2"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EEF6FF"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#D6EAF8"/>
                                    <Setter Property="Foreground" Value="#1B4F7A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold" FontSize="12"/>
                                <!-- One badge per tag — visible only when that tag is present -->
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <Border Background="#2A6A9E" CornerRadius="2" Padding="4,1"
                                            Visibility="{Binding HasBuiltIn, Converter={StaticResource BoolVis}}">
                                        <TextBlock Text="Built-in" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <Border Background="#8E44AD" CornerRadius="2" Padding="4,1" Margin="2,0,0,0"
                                            Visibility="{Binding HasDynamic, Converter={StaticResource BoolVis}}">
                                        <TextBlock Text="Dynamic" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <Border Background="#27AE60" CornerRadius="2" Padding="4,1" Margin="2,0,0,0"
                                            Visibility="{Binding HasCustom, Converter={StaticResource BoolVis}}">
                                        <TextBlock Text="Custom" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#D0D8E0" ShowsPreview="False"/>

            <!-- Details -->
            <Border Grid.Column="2" Padding="20,16" Background="White">
                <StackPanel x:Name="DetailPanel">
                    <!-- Naam -->
                    <TextBlock Text="Name" Foreground="#1B4F7A"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="TemplateNameBox"
                             FontSize="13" Padding="6,4"
                             BorderBrush="#C0CDD8" BorderThickness="1"
                             IsReadOnly="False"
                             Margin="0,0,0,14"
                             ToolTip="Template name (editable for custom templates)"/>

                    <!-- Description -->
                    <TextBlock Text="Description" Foreground="#1B4F7A"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="TemplateDescBox"
                             FontSize="11" Padding="6,4"
                             BorderBrush="#C0CDD8" BorderThickness="1"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             Height="80" VerticalScrollBarVisibility="Auto"
                             IsReadOnly="False"
                             Margin="0,0,0,16"
                             ToolTip="Short description of the template"/>

                    <!-- Info chip -->
                    <Border x:Name="TypeChip" CornerRadius="3"
                            Padding="8,3" HorizontalAlignment="Left"
                            Margin="0,0,0,0">
                        <TextBlock x:Name="TypeLabel" FontSize="10" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Knoppen onderaan ── -->
        <Border Grid.Row="3" Background="#EEF3F8"
                BorderBrush="#D0D8E0" BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="SaveButton"
                            Content="&#x1F4BE;  Save as Template"
                            Click="Save_Click"
                            Padding="10,6" Margin="0,0,8,0"
                            ToolTip="Save the current table layout as a new template">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="#2A6A9E"/>
                                <Setter Property="Foreground"   Value="White"/>
                                <Setter Property="BorderBrush"  Value="#3A7AB0"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor"       Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3A7AB0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="DeleteButton"
                            Content="&#x1F5D1;  Delete"
                            Click="Delete_Click"
                            Padding="10,6"
                            IsEnabled="False"
                            ToolTip="Delete this custom template (built-in and dynamic templates cannot be deleted)">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="#C0392B"/>
                                <Setter Property="Foreground"   Value="White"/>
                                <Setter Property="BorderBrush"  Value="#E74C3C"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor"       Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E74C3C"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Width="90" Height="32"
                            Click="Cancel_Click"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="White"/>
                                <Setter Property="Foreground"   Value="#333"/>
                                <Setter Property="BorderBrush"  Value="#C0CDD8"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor"       Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3" Padding="8,4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F0F4F8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="LoadButton"
                            Content="&#x25B6;  Load"
                            Width="100" Height="32"
                            IsEnabled="False"
                            Click="Load_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"   Value="#1B4F7A"/>
                                <Setter Property="Foreground"   Value="White"/>
                                <Setter Property="BorderBrush"  Value="#2A6A9E"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontWeight"   Value="SemiBold"/>
                                <Setter Property="Cursor"       Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3" Padding="8,4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2A6A9E"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
