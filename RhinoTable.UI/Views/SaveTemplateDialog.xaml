<Window x:Class="RhinoTable.UI.Views.SaveTemplateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Template"
        Width="380" Height="245"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#F2F5F8">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Template Name" FontWeight="Bold" FontSize="11"
                   Foreground="#1B4F7A" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox" Grid.Row="1"
                 Padding="6,4" BorderBrush="#C0CDD8" BorderThickness="1"
                 FontSize="13" Margin="0,0,0,12"
                 ToolTip="Enter a unique name for this template"/>

        <TextBlock Grid.Row="2" Text="Description (optional)" FontWeight="Bold" FontSize="11"
                   Foreground="#1B4F7A" Margin="0,0,0,4"/>
        <TextBox x:Name="DescBox" Grid.Row="3"
                 Padding="6,4" BorderBrush="#C0CDD8" BorderThickness="1"
                 FontSize="11" Height="50" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" Height="28" Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Save" Width="80" Height="28" IsDefault="True"
                    Background="#1B4F7A" Foreground="White"
                    BorderBrush="#2A6A9E" Click="Ok_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background"  Value="#1B4F7A"/>
                        <Setter Property="Foreground"  Value="White"/>
                        <Setter Property="BorderBrush" Value="#2A6A9E"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1" CornerRadius="3" Padding="8,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2A6A9E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
