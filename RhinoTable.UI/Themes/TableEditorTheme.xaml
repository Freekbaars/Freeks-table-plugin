<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Toolbar-groep container ────────────────────────────────────────── -->
    <Style x:Key="ToolGroup" TargetType="Border">
        <Setter Property="Background"       Value="#1E5A8A"/>
        <Setter Property="CornerRadius"     Value="4"/>
        <Setter Property="Padding"          Value="8,4"/>
        <Setter Property="Margin"           Value="0,0,0,0"/>
    </Style>

    <Style x:Key="GroupLabel" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="#A8C8E8"/>
        <Setter Property="FontSize"     Value="9"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Margin"       Value="0,0,0,4"/>
    </Style>

    <!-- Verticale scheiding tussen groepen -->
    <Style x:Key="GroupSep" TargetType="Rectangle">
        <Setter Property="Width"    Value="1"/>
        <Setter Property="Fill"     Value="#FFFFFF"/>
        <Setter Property="Opacity"  Value="0.15"/>
        <Setter Property="Margin"   Value="6,4"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>

    <!-- ── Knoppen ────────────────────────────────────────────────────────── -->
    <!-- Standaard toolbar-knop (licht op donkerblauwe achtergrond) -->
    <Style x:Key="ToolbarButton" TargetType="Button">
        <Setter Property="Foreground"       Value="White"/>
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="BorderBrush"      Value="Transparent"/>
        <Setter Property="Padding"          Value="7,4"/>
        <Setter Property="Margin"           Value="1,1"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="MinHeight"        Value="26"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background"   Value="#3A7AB0"/>
                            <Setter Property="BorderBrush"  Value="#5A9AD0"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#2A6A9E"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Verwijder-knop (rode hover) -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background"  Value="#C0392B"/>
                <Setter Property="BorderBrush" Value="#E74C3C"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Primaire knop (groen) -->
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
        <Setter Property="Background"   Value="#27834E"/>
        <Setter Property="BorderBrush"  Value="#27834E"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Padding"      Value="12,5"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background"  Value="#2ECC71"/>
                <Setter Property="BorderBrush" Value="#2ECC71"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#1F6B3E"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Dropdown-toggle (zelfde look als ToolbarButton, maar voor ToggleButton) -->
    <Style x:Key="DropdownToggleButton" TargetType="ToggleButton">
        <Setter Property="Foreground"       Value="White"/>
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="BorderBrush"      Value="Transparent"/>
        <Setter Property="Padding"          Value="8,4"/>
        <Setter Property="Margin"           Value="1,1"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background"  Value="#3A7AB0"/>
                            <Setter Property="BorderBrush" Value="#5A9AD0"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Background"  Value="#2A6A9E"/>
                            <Setter Property="BorderBrush" Value="#5A9AD0"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Kleine kleurvlak-knop (16×16) voor kleurpalet -->
    <Style x:Key="SwatchButton" TargetType="Button">
        <Setter Property="Width"           Value="17"/>
        <Setter Property="Height"          Value="17"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="Margin"          Value="1,0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush"     Value="#8AABE0"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Kleine patroon-knop (22×17) met tekst-symbool -->
    <Style x:Key="PatternButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
        <Setter Property="Width"   Value="22"/>
        <Setter Property="Height"  Value="17"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin"  Value="1,0"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="MinHeight" Value="17"/>
    </Style>

    <!-- ── Eigenschappen-strip labels en invoervelden ─────────────────────── -->
    <Style x:Key="PropLabel" TargetType="TextBlock">
        <Setter Property="Foreground"       Value="#555E6A"/>
        <Setter Property="FontSize"         Value="11"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin"           Value="0,0,5,0"/>
    </Style>

    <Style x:Key="PropBox" TargetType="TextBox">
        <Setter Property="FontSize"             Value="12"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Height"               Value="26"/>
        <Setter Property="Padding"              Value="4,0"/>
        <Setter Property="BorderBrush"          Value="#C0C8D4"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="Background"           Value="#F8FAFC"/>
    </Style>

    <Style x:Key="PropComboBox" TargetType="ComboBox">
        <Setter Property="FontSize"             Value="12"/>
        <Setter Property="Height"               Value="26"/>
        <Setter Property="Padding"              Value="4,0"/>
        <Setter Property="BorderBrush"          Value="#C0C8D4"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="Background"           Value="#F8FAFC"/>
        <Setter Property="MaxDropDownHeight"    Value="220"/>
        <Setter Property="IsEditable"           Value="True"/>
    </Style>

    <!-- ── DataGrid ───────────────────────────────────────────────────────── -->
    <Style TargetType="DataGrid">
        <Setter Property="Background"           Value="White"/>
        <Setter Property="AlternatingRowBackground" Value="#F6F8FB"/>
        <Setter Property="RowBackground"        Value="White"/>
        <Setter Property="BorderThickness"      Value="0"/>
        <Setter Property="FontSize"             Value="12"/>
        <Setter Property="RowHeight"            Value="26"/>
    </Style>

    <!-- Kolomkopjes -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background"               Value="#1B4F7A"/>
        <Setter Property="Foreground"               Value="White"/>
        <Setter Property="FontWeight"               Value="SemiBold"/>
        <Setter Property="FontSize"                 Value="11"/>
        <Setter Property="Padding"                  Value="8,5"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="BorderBrush"              Value="#144060"/>
        <Setter Property="BorderThickness"          Value="0,0,1,1"/>
        <Setter Property="MinHeight"                Value="28"/>
    </Style>

    <!-- Rijkopjes (rijnummers) -->
    <Style TargetType="DataGridRowHeader">
        <Setter Property="Background"           Value="#EEF2F7"/>
        <Setter Property="Foreground"           Value="#7A8899"/>
        <Setter Property="FontSize"             Value="10"/>
        <Setter Property="FontWeight"           Value="SemiBold"/>
        <Setter Property="BorderBrush"          Value="#D0D8E0"/>
        <Setter Property="BorderThickness"      Value="0,0,1,0"/>
        <Setter Property="Width"                Value="36"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <!-- Cel -->
    <Style TargetType="DataGridCell">
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Padding"          Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background"   Value="#D6E8F8"/>
                <Setter Property="BorderBrush"  Value="#4A90D9"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush"      Value="#2172C4"/>
                <Setter Property="BorderThickness"  Value="1"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
